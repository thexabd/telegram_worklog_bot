# Generate from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram usernames allowed to use the bot (with or without @, case-insensitive)
TELEGRAM_ALLOWED_USERNAMES=
# Your Giithub PAT
GITHUB_TOKEN=
# Organisation's name or your username
GITHUB_OWNER=
# Optional: default repo so users can send a bare issue number (e.g. "123")
GITHUB_REPO=
# Project number from the project URL: github.com/users/<owner>/projects/<NUMBER>
GITHUB_PROJECT_NUMBER=

# --- Deployment (webhook mode) ---
# Public HTTPS URL of the deployed service (e.g. https://my-bot.onrender.com).
# When set, the bot runs in webhook mode and listens on $PORT.
# Leave blank for local long-polling.
WEBHOOK_URL=
# Optional: override the random secret path segment. Defaults to a hash of the
# bot token. Anyone with this value can POST fake updates, so keep it secret.
WEBHOOK_SECRET=
# PORT is provided by the host (Render sets this automatically). Defaults to 3000.
PORT=
