# Generate from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# 32-byte hex (64 chars). Generate with: npm run gen-key
ENCRYPTION_KEY=
# Organisation's name or your username
GITHUB_OWNER=
# Optional: default repo so users can send a bare issue number (e.g. "123")
GITHUB_REPO=
# Project number from the project URL: github.com/users/<owner>/projects/<NUMBER>
GITHUB_PROJECT_NUMBER=
# Optional: SQLite path for per-user encrypted PATs. Default: data/users.db
SQLITE_PATH=
